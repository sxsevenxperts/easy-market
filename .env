# Smart Market - Environment Variables for Production Deployment
# This file contains sensitive data - NEVER commit to version control in real projects

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/smart_market
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# API Configuration
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# CORS - Configure com seus domínios
ALLOWED_ORIGINS=https://smart-market.sevenxperts.com,https://app.smart-market.com

# JWT Configuration - ALTERE ISTO EM PRODUÇÃO!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# Redis (optional) - Use para cache e sessions
REDIS_URL=redis://localhost:6379

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Application Settings
APP_NAME=smart-market
APP_VERSION=3.0.0
