# Smart Market Environment Configuration
# Copy this to .env.local and add your real credentials

NODE_ENV=production
PORT=3000

# Database (Supabase)
# Get these from: https://app.supabase.com
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_key_here

# Weather API (OpenWeather)
# Get this from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# Security
JWT_SECRET=your_jwt_secret_here

# Redis (Optional)
REDIS_HOST=redis
REDIS_PORT=6379

# API Configuration
API_PREFIX=/api/v1
CORS_ORIGIN=*

# Store Configuration
LOJA_IDS=loja_001,loja_002,loja_003
SCRAPER_INTERVAL=60
