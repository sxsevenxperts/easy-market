  "version": "0.1.0",
  "description": "Easy Market - Retail Intelligence Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "tsc",
    "lint": "eslint src/**/*.js",
