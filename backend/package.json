    "@fastify/cors": "^8.4.0",
    "@fastify/jwt": "^7.0.0",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "joi": "^17.11.0",
    "axios": "^1.6.4",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "node-schedule": "^2.1.1",
    "cron": "^3.1.7",
    "nodemailer": "^6.9.7",
    "twilio": "^4.8.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
