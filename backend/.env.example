# Easy Market Backend - Variáveis de Ambiente
# Copy this file to .env and fill in your actual values

# ============================================
# Environment
# ============================================
NODE_ENV=production

# ============================================
# Server Configuration
# ============================================
PORT=3000
API_PREFIX=/api/v1
CORS_ORIGIN=https://diversos-easymarket.yuhqmc.easypanel.host,http://localhost:3001

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d

# ============================================
# Database (PostgreSQL via Supabase)
# ============================================
DB_HOST=qfkwqfrnemqregjqxkcr.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-password
DB_SSL=require

# ============================================
# Supabase (Alternative format)
# ============================================
SUPABASE_URL=https://qfkwqfrnemqregjqxkcr.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ============================================
# Redis (Optional - for caching)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Email Notifications (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@easymarket.com

# ============================================
# SMS Notifications (Twilio - Optional)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Integration Webhooks
# ============================================
PDV_WEBHOOK_SECRET=your-pdv-webhook-secret
BALANCE_WEBHOOK_SECRET=your-balance-webhook-secret

# ============================================
# Feature Flags
# ============================================
ENABLE_PREDICTIVE_ANALYTICS=true
ENABLE_SCHEDULER=true
ENABLE_REAL_TIME_ALERTS=true
