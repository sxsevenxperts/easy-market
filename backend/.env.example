# Smart Market - Environment Variables Template
# Copy this to .env and fill with your values

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/smart_market
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# API Configuration
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# CORS
CORS_ORIGIN=https://frontend-domain.com,http://localhost:3001

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password