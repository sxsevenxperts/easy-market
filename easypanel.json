{
  "name": "smart-market",
  "version": "3.0.0",
  "description": "Smart Market - Plataforma de gestão comercial inteligente",
  "services": {
    "backend": {
      "type": "app",
      "source": {
        "type": "dockerfile"
      },
      "build": {
        "dockerfile": "Dockerfile",
        "context": "."
      },
      "deploy": {
        "replicas": 1,
        "restartPolicy": "unless-stopped"
      },
      "env": [
        "PORT=3000",
        "NODE_ENV=production",
        "SUPABASE_URL=",
        "SUPABASE_SERVICE_KEY=",
        "JWT_SECRET=",
        "ALLOWED_ORIGINS=",
        "OPENWEATHER_API_KEY=",
        "REDIS_HOST=localhost",
        "REDIS_PORT=6379",
        "REDIS_PASSWORD=",
        "LOJA_IDS=loja_001,loja_002,loja_003",
        "SCRAPER_INTERVAL=60"
      ],
      "ports": [
        {
          "published": 3000,
          "target": 3000,
          "protocol": "tcp"
        }
      ],
      "healthCheck": {
        "path": "/health",
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 20
      },
      "resources": {
        "memory": "512m",
        "cpu": "0.5"
      }
    }
  }
}