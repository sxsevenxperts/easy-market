# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=easy_market
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# API
# ============================================
API_BASE_URL=http://localhost:3000
ML_ENGINE_PORT=5000
DEBUG=False

# ============================================
# FEATURES
# ============================================
# Modelos para usar (prophet, xgboost, linear)
MODELS_ENABLED=prophet,xgboost

# Períodos de previsão padrão (horas)
PREDICTION_PERIODS=6,12,24,48,72

# ============================================
# SCHEDULER
# ============================================
# Ativar scheduler automático
SCHEDULER_ENABLED=True

# Executar previsões a cada N minutos
PREDICTION_INTERVAL=60

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=ml_engine.log
